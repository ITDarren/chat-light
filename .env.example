# VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# In local development: copy this file to .env.local and fill in your key.
# In GitHub Actions: set as repository secret GEMINI_API_KEY (injected at build time).
# ⚠️  WARNING: This key will be bundled in the frontend JS — do NOT use a high-quota production key.
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted (optional, for reference only).
APP_URL="https://<your-github-username>.github.io/chat-light/"
